{
  "name": "@arc/seller",
  "private": true,
  "type": "module",
  "description": "Seller app for arc built with Nuxt 3, TypeScript, Pinia, and Nuxt UI",
  "scripts": {
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "devtools:enable": "npx nuxi@latest devtools enable",
    "devtools:disable": "npx nuxi@latest devtools disable",
    "typecheck": "npx nuxi typecheck",
    "test": "vitest run test",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up"
  },
  "devDependencies": {
    "@dauphaihau/eslint-config": "^0.1.5",
    "@eslint/eslintrc": "^3.1.0",
    "@nuxt/devtools": "^1.3.14",
    "@nuxt/eslint": "^0.3.13",
    "@nuxt/image": "^1.6.0",
    "@nuxt/test-utils": "^3.9.0",
    "@nuxtjs/color-mode": "^3.3.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/i18n": "^8.0.0",
    "@samk-dev/nuxt-vcalendar": "^1.0.2",
    "@types/eslint__eslintrc": "^2.1.1",
    "@types/node": "^22.13.13",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/browser": "^2.1.3",
    "@vue/test-utils": "^2.4.3",
    "@vueuse/core": "^10.7.0",
    "@vueuse/nuxt": "^10.7.0",
    "eslint": "^9.5.0",
    "eslint-plugin-import-x": "^0.5.1",
    "eslint-plugin-tailwindcss": "^3.17.3",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^8.0.3",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.0",
    "nuxt-security": "2.0.0-rc.7",
    "typescript": "^5.5.4",
    "vitest": "^1.1.0",
    "vue-eslint-parser": "^9.3.2",
    "vue-router": "^4.2.5",
    "vue-tsc": "^2.0.29"
  },
  "dependencies": {
    "@arc/composables": "workspace:*",
    "@arc/contracts": "workspace:*",
    "@arc/enums": "workspace:*",
    "@arc/lib": "workspace:*",
    "@arc/models": "workspace:*",
    "@arc/schemas": "workspace:*",
    "@arc/ui": "workspace:*",
    "@arc/utils": "workspace:*",
    "@formkit/auto-animate": "^0.8.1",
    "@hebilicious/vue-query-nuxt": "^0.3.0",
    "@nuxt/ui": "^2.18.4",
    "@pinia/nuxt": "^0.5.1",
    "@tailwindcss/typography": "^0.5.10",
    "@tanstack/vue-query": "^5.45.0",
    "dayjs": "^1.11.10",
    "http-status-codes": "^2.3.0",
    "nuxt": "~3.12.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.38",
    "zod": "^3.22.4"
  },
  "web-types": "./web-types.json",
  "packageManager": "pnpm@9.0.0"
}
