{
  "name": "arc-web-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "husky install",
    "dev:storefront": "pnpm --filter @arc/storefront dev",
    "dev:seller": "pnpm --filter @arc/seller dev",
    "build": "pnpm run build:storefront",
    "build:storefront": "pnpm --filter @arc/storefront build",
    "build:seller": "pnpm --filter @arc/seller build",
    "generate": "pnpm run generate:storefront",
    "generate:storefront": "pnpm --filter @arc/storefront generate",
    "generate:seller": "pnpm --filter @arc/seller generate",
    "preview": "pnpm run preview:storefront",
    "preview:storefront": "pnpm --filter @arc/storefront preview",
    "preview:seller": "pnpm --filter @arc/seller preview",
    "start": "pnpm run start:storefront",
    "start:storefront": "pnpm --filter @arc/storefront start",
    "start:seller": "pnpm --filter @arc/seller start",
    "typecheck": "pnpm run typecheck:storefront",
    "typecheck:storefront": "pnpm --filter @arc/storefront typecheck",
    "typecheck:seller": "pnpm --filter @arc/seller typecheck",
    "test": "pnpm run test:storefront",
    "test:storefront": "pnpm --filter @arc/storefront test",
    "test:seller": "pnpm --filter @arc/seller test",
    "lint": "pnpm run lint:storefront",
    "lint:fix": "pnpm run lint:fix:storefront",
    "lint:storefront": "pnpm --filter @arc/storefront lint",
    "lint:seller": "pnpm --filter @arc/seller lint",
    "lint:fix:storefront": "pnpm --filter @arc/storefront lint:fix",
    "lint:fix:seller": "pnpm --filter @arc/seller lint:fix",
    "lint:packages": "eslint --cache --no-warn-ignored --config apps/storefront/eslint.config.js \"packages/**/*.{js,ts,vue}\"",
    "lint:packages:fix": "eslint --cache --fix --no-warn-ignored --config apps/storefront/eslint.config.js \"packages/**/*.{js,ts,vue}\""
  },
  "lint-staged": {
    "apps/storefront/**/*.{js,ts,vue}": [
      "eslint --cache --fix --no-warn-ignored --config apps/storefront/eslint.config.js"
    ],
    "apps/seller/**/*.{js,ts,vue}": [
      "eslint --cache --fix --no-warn-ignored --config apps/seller/eslint.config.js"
    ],
    "packages/**/*.{js,ts,vue}": [
      "pnpm lint:packages:fix"
    ]
  },
  "author": {
    "name": "Hau Tran",
    "email": "contact@hautran.me",
    "url": "https://github.com/dauphaihau"
  },
  "volta": {
    "node": "20.20.2"
  }
}
